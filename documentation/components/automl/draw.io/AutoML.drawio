        <mxCell id="LmWJH-1FNEly_s8O4EBX-31" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Full refit&lt;/h1&gt;&lt;p style=&quot;font-size: 16px;&quot;&gt;Refit best candidates on full data using AutoGluon. Let&#39;s explore &lt;b&gt;Katib&lt;/b&gt; for distributed computing here and experiment/trials logging.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="825" y="40" width="267" height="145" as="geometry" />
        </mxCell>
        <mxCell id="LmWJH-1FNEly_s8O4EBX-32" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Build &amp;amp; eval&lt;/h1&gt;&lt;p style=&quot;font-size: 16px;&quot;&gt;Build Pipeline Models using sample of data (500) &amp;amp; AutoGluon lib. Promote best ones to next stage.&amp;nbsp;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="162" y="-308" width="256" height="150" as="geometry" />
        </mxCell>
        <mxCell id="LmWJH-1FNEly_s8O4EBX-33" value="&lt;font color=&quot;#000000&quot; style=&quot;font-size: 18px;&quot;&gt;Model HPO&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fillColor=#60a917;fontColor=#ffffff;strokeColor=#2D7600;dashed=1;fillStyle=dashed;" parent="1" vertex="1">
          <mxGeometry x="523" y="-137" width="256" height="100" as="geometry" />
        </mxCell>
        <mxCell id="LmWJH-1FNEly_s8O4EBX-34" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Data Loader&lt;/h1&gt;&lt;p style=&quot;font-size: 16px;&quot;&gt;Read the tabular data from data source (S3, FS). Torch compatible data loader to be explored. Data cache support to be explored in next stage.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="-631" y="-308" width="254" height="150" as="geometry" />
        </mxCell>
        <mxCell id="LmWJH-1FNEly_s8O4EBX-35" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Data split/sample&lt;/h1&gt;&lt;p style=&quot;font-size: 16px;&quot;&gt;Split the data to train / test. Sample using correct sampling technique (random, stratified, ts-driven)&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="-234" y="-308" width="254" height="150" as="geometry" />
        </mxCell>
        <mxCell id="LmWJH-1FNEly_s8O4EBX-37" value="Kubeflow Pipeline&lt;br&gt;Component" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="810" y="-331" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="LmWJH-1FNEly_s8O4EBX-38" value="&lt;font color=&quot;#000000&quot;&gt;Kubeflow Pipeline&lt;br&gt;Component &amp;amp; Kubeflow Katib&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fillColor=#60a917;fontColor=#ffffff;strokeColor=#2D7600;" parent="1" vertex="1">
          <mxGeometry x="954" y="-331" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="LmWJH-1FNEly_s8O4EBX-39" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Model registry&lt;/h1&gt;&lt;p style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;Marked as optional step&lt;/b&gt;&amp;nbsp;(auto_register=True ?). The storage and deployment happens outside the train pipeline,&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;Register AutoGluon Predictor with best model metadata for deployment purposes. AutoGluon keeps under the hood all models trained but uses best one by default (+ required base ones).&lt;/span&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="825" y="362.5" width="330" height="230.5" as="geometry" />
        </mxCell>
        <mxCell id="LmWJH-1FNEly_s8O4EBX-41" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Model HPO&lt;/h1&gt;&lt;p style=&quot;font-size: 16px;&quot;&gt;[NOT IN SCOPE]&lt;br&gt;AutoGluon does not recommend HPO; instead &lt;b&gt;Ensembling &lt;/b&gt;(stacking/bagging) approach is taken.. To be explored POST-MVP.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="825" y="-140" width="267" height="145" as="geometry" />
        </mxCell>
