        <mxCell id="LmWJH-1FNEly_s8O4EBX-19" value="&lt;font color=&quot;#000000&quot; style=&quot;font-size: 18px;&quot;&gt;Model registry&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fillColor=#647687;fontColor=#ffffff;strokeColor=#314354;" parent="1" vertex="1">
