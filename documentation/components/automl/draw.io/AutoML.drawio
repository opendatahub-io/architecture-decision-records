        <mxCell id="LmWJH-1FNEly_s8O4EBX-42" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Leaderboard evaluate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
